# Revendu Backend Environment Configuration
# Copy to .env and adjust for your environment

# ──────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT
# ──────────────────────────────────────────────────────────────────────────────

# One of: development, staging, production, test
ENVIRONMENT=development

# ──────────────────────────────────────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────────────────────────────────────

# Development (local PostgreSQL on docker-compose)
DATABASE_URL=postgresql+asyncpg://revendu:revendu@localhost:5435/revendu

# Production: Use a managed database (e.g. Railway, Neon, Supabase)
# Example format: postgresql+asyncpg://user:pass@host:port/dbname
# DATABASE_URL=postgresql+asyncpg://user:securepass@prod-db.railway.app:5432/revendu

# ──────────────────────────────────────────────────────────────────────────────
# JWT & AUTHENTICATION
# ──────────────────────────────────────────────────────────────────────────────

# Development: placeholder key (not used in production)
JWT_SECRET=change-me-in-production-use-256-bit-random-secret

# Production: Generate a 256-bit random secret via:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# JWT_SECRET=your-256-bit-random-secret-here

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ──────────────────────────────────────────────────────────────────────────────
# CORS & FRONTEND
# ──────────────────────────────────────────────────────────────────────────────

# Development: Next.js frontend on localhost:3000
CORS_ORIGINS=http://localhost:3000

# Production: Your production frontend domain
# CORS_ORIGINS=https://app.revendu.fr,https://www.revendu.fr

# Frontend URL (used for redirects in OAuth flows, etc)
FRONTEND_URL=http://localhost:3000
# FRONTEND_URL=https://app.revendu.fr

# ──────────────────────────────────────────────────────────────────────────────
# RATE LIMITING
# ──────────────────────────────────────────────────────────────────────────────

# Development: higher limits for testing
RATE_LIMIT_LOGIN=10000/minute

# Production: stricter limits
# RATE_LIMIT_LOGIN=10/minute

# ──────────────────────────────────────────────────────────────────────────────
# STRIPE PAYMENTS (Optional)
# ──────────────────────────────────────────────────────────────────────────────

# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_test_...
STRIPE_PRO_PRICE_ID=price_...

# Production versions:
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_live_...
# STRIPE_PRO_PRICE_ID=price_...

# ──────────────────────────────────────────────────────────────────────────────
# GOOGLE OAUTH (Gmail Sync, Optional)
# ──────────────────────────────────────────────────────────────────────────────

# Create OAuth 2.0 credentials at https://console.cloud.google.com/
# Type: Desktop application (or Web application for production)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/sync/gmail/callback

# Production redirect URI must match your backend domain:
# GOOGLE_REDIRECT_URI=https://api.revendu.fr/api/v1/sync/gmail/callback
